import fetch from 'node-fetch'

const tiktokCommand = {
    name: 'tiktok',
    alias: ['tt', 'tts'],
    category: 'downloader',
    isOwner: false,
    noPrefix: true,
    isAdmin: false,
    isGroup: false,

    run: async (conn, m, { text, command }) => {
        const chat = m.key.remoteJid

        if (!text) {
            return conn.sendMessage(chat, {
                text: `рҹ–Ө *ВҝQuГ© quieres buscar en TikTok?*\n\nEjemplo: \`${command} gatos\``
            }, { quoted: m })
        }

        const isUrl = /tiktok\.com/.test(text)

        const endpoint = isUrl
            ? `https://api.stellarwa.xyz/dl/tiktok?url=${encodeURIComponent(text)}&key=YukiWaBot`
            : `https://api.stellarwa.xyz/search/tiktok?query=${encodeURIComponent(text)}&key=YukiWaBot`

        try {
            await conn.sendMessage(chat, { react: { text: 'вҸі', key: m.key } })

            const res = await fetch(endpoint)
            const json = await res.json()

            if (!json.status) {
                return conn.sendMessage(chat, {
                    text: '> вңҗ No se encontrГі contenido vГЎlido.'
                }, { quoted: m })
            }

            // вҡЎ Mensaje rГЎpido (como tu play)
            const { key } = await conn.sendMessage(chat, {
                text: 'рҹ“Ҙ *Procesando TikTok...*'
            })

            if (isUrl) {
                const v = json.data
                const videoUrl = Array.isArray(v.dl) ? v.dl[0] : v.dl

                const caption = `г…ӨЫҹвҲ©гҖҖЧ…гҖҖвҳ… а»ҢгҖҖЧ…гҖҖрҹ…Јрқ—Ӯрқ—„рқ–ірқ—Ҳрқ—„ рҹ…“ownloadгҖҖЧ„б°ҷ

р–ЈЈЦ¶г…ӨЦҜвҢ— вңҺ  Ч„ в¬ӯ *TГӯtulo:* ${v.title || 'Sin tГӯtulo'}
р–ЈЈЦ¶г…ӨЦҜвҢ— к•Ҙ  Ч„ в¬ӯ *Autor:* ${v.author?.nickname || 'Desconocido'}
р–ЈЈЦ¶г…ӨЦҜвҢ— вҙө  Ч„ в¬ӯ *DuraciГіn:* ${v.duration || 'N/A'}
р–ЈЈЦ¶г…ӨЦҜвҢ— вқ–  Ч„ в¬ӯ *Likes:* ${(v.stats?.likes || 0).toLocaleString()}
р–ЈЈЦ¶г…ӨЦҜвҢ— вңҝ  Ч„ в¬ӯ *Vistas:* ${(v.stats?.views || 0).toLocaleString()}`.trim()

                await conn.sendMessage(chat, {
                    video: { url: videoUrl },
                    caption
                }, { quoted: m })

            } else {
                const results = json.data?.slice(0, 3)

                for (let v of results) {
                    if (!v.dl) continue

                    await conn.sendMessage(chat, {
                        video: { url: v.dl },
                        caption: `рҹҺө ${v.title || 'Sin tГӯtulo'}`
                    }, { quoted: m })
                }
            }

            await conn.sendMessage(chat, {
                text: 'вң… *Contenido enviado con Г©xito*',
                edit: key
            })

            await conn.sendMessage(chat, { react: { text: 'рҹҺ¶', key: m.key } })

        } catch (e) {
            console.error(e)

            await conn.sendMessage(chat, {
                text: 'вқҢ *Error al procesar TikTok*'
            }, { quoted: m })
        }
    }
}

export default tiktokCommand
